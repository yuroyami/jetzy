<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="${appName}"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.splash">

        <!-- uiMode/density/screenLayout/smallestScreenSize: without these, a scheduled dark-mode
             flip or a foldable unfold mid-transfer recreates the Activity — dropping
             KEEP_SCREEN_ON and leaving live managers holding the destroyed instance. -->
        <activity
            android:name="jetzy.MainActivity"
            android:configChanges="orientation|keyboardHidden|screenSize|uiMode|density|screenLayout|smallestScreenSize"
            android:exported="true"
            android:imeOptions="flagNoExtractUi"
            android:fitsSystemWindows="true"
            android:windowSoftInputMode="adjustNothing">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>