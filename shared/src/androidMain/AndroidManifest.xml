<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" tools:targetApi="31" />

    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:usesPermissionFlags="neverForLocation" android:required="true"
        tools:targetApi="31" android:maxSdkVersion="32" tools:ignore="CoarseFineLocation"
        />
    <uses-permission android:required="true" android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:required="true" android:name="android.permission.CHANGE_WIFI_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />

    <!-- Foreground service support so transfers survive app-backgrounding. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Notification permission needed (API 33+) for the foreground-service notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Battery optimization opt-out so the OS doesn't kill us mid-transfer. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Bluetooth Classic SPP transport (fallback when Wi-Fi-based paths fail). API 31+
         splits BT permissions into _CONNECT (pair/socket) and _SCAN (discovery); older
         APIs used the umbrella BLUETOOTH/BLUETOOTH_ADMIN, both kept for compatibility. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" tools:targetApi="31" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />

    <uses-feature
        android:name="android.hardware.wifi.direct"
        android:required="false" />

    <!-- Wi-Fi Aware (NAN). Optional — devices without the chip silently fall back
         to HotspotLAN, no app behavior change for them. Required=false keeps the
         app installable on phones lacking the feature (most phones from before ~2020). -->
    <uses-feature
        android:name="android.hardware.wifi.aware"
        android:required="false" />

    <application>
        <service
            android:name="jetzy.services.JetzyForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
